# Copie para .env e ajuste (não commite o .env com senha real).
# Formato: UMA linha, sem espaço antes/depois do =

# MongoDB (Atlas, local, etc.) — o Program.cs usa isso se MongoDbSettings:ConnectionString estiver vazio no appsettings
DATABASE_URL=mongodb://127.0.0.1:27017

# Opcional (sobrescreve appsettings):
# MongoDbSettings__DatabaseName=pim
